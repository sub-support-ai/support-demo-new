APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── AI Service (self-hosted) ─────────────────────────────────────────────────
# Адрес локального AI-сервиса. По требованию заказчика данные не покидают
# периметр предприятия: Mistral крутится рядом, в соседнем контейнере
# (Ollama / llama.cpp). Никаких облачных API.
#
# В docker-compose это http://ai-service:8001 — имя сервиса из того же
# compose-файла. В staging/prod — адрес на внутренней сети заказчика.
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_API_KEY=
AI_SERVICE_TIMEOUT_SECONDS=180
KNOWLEDGE_SEMANTIC_SEARCH_ENABLED=false
KNOWLEDGE_EMBEDDING_DIMENSION=768
KNOWLEDGE_REINDEX_INTERVAL_SECONDS=0
AI_WORKER_STALE_RUNNING_SECONDS=600
KNOWLEDGE_EMBEDDING_WORKER_STALE_RUNNING_SECONDS=900

# ── RAG: пороги принятия решения ─────────────────────────────────────────────
# Скор статьи KB складывается из text_score + context + freshness + feedback
# (см. _score_article в knowledge_base.py). Распределение скора зависит от
# конкретной KB заказчика и веса FTS / semantic — поэтому пороги выносим
# в .env, а не зашиваем в код. Меняются без релиза.
#
# >= HIGH      → "answer"   — отдаём решение пользователю
# >= MEDIUM    → "clarify"  — статья похожа, просим уточнить контекст
# < MEDIUM     → "escalate" — статья не подходит, нужен агент
#
# Валидация в config.py: оба > 0 и MEDIUM <= HIGH (иначе порядок сломан).
RAG_SCORE_HIGH_THRESHOLD=8.0
RAG_SCORE_MEDIUM_THRESHOLD=4.0

# Порог по confidence модели для «красной зоны»: даже если AI не запросил
# эскалацию, при confidence < этого значения мы всё равно поднимаем флаг
# requires_escalation (фронт показывает кнопку «Создать тикет»).
# Диапазон [0, 1]; 0 = красная зона выключена, 1 = всё всегда красная зона.
RAG_CONFIDENCE_RED_ZONE=0.6

# ── JWT ──────────────────────────────────────────────────────────────────────
# Длинная случайная строка. Сгенерить:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# В APP_ENV=production дефолтное значение запрещено (см. app/config.py).
JWT_SECRET_KEY=

JWT_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────────────────
# Список origin'ов через запятую, откуда браузер может стучать на API.
# Пример (dev):    CORS_ORIGINS=http://localhost:3000
# Пример (prod):   CORS_ORIGINS=https://support.acme.com,https://admin.acme.com
# Пустая строка — CORS отключён (ок если фронта ещё нет).
# "*" НЕ ПОДДЕРЖИВАЕТСЯ — это дыра в безопасности.
# CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://supportpoint.duckdns.org

# ── Bootstrap-admin ──────────────────────────────────────────────────────────
# Первый пользователь с этим email, который зарегистрируется через
# POST /auth/register, автоматически получит role=admin.
# Решает "курицу-яйцо": без этого первого админа негде взять.
# Если переменная пустая — никто не становится админом при регистрации.
# После того как первый админ создан, переменную можно убрать из .env.
BOOTSTRAP_ADMIN_EMAIL=

# ── Rate limiter ─────────────────────────────────────────────────────────────
# Где хранить счётчики попыток для /auth/login и /auth/register.
#
#   memory  — в процессе (по uvicorn-воркеру отдельные). Ок для self-hosted
#             с одним worker'ом, для демо.
#   redis   — общий счётчик через ZSET sliding-window. Нужен, если backend
#             крутится в нескольких pod'ах: иначе лимит «5/мин» становится
#             «5 × N pod'ов», и брутфорс не остановить.
#
# Опечатка в значении ловится при старте (см. config.py).
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
